{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      }
    },
    "testing": {
      "distribution": "internal",
      "channel": "testing",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:clean :app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease --stacktrace"
      },
      "env": {
        "APP_ENV": "testing",
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=1g -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError -Dorg.gradle.daemon=false -Dorg.gradle.parallel=false -Dorg.gradle.workers.max=2"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
