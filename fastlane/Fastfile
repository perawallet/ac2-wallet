# Fastfile for AC2 Controller App
#
# Builds iOS (-> TestFlight) and Android (-> Firebase App Distribution). The
# native ios/ and android/ folders are gitignored and regenerated by
# `expo prebuild` before these lanes run, so the scheme/workspace are
# auto-detected. Bundle identifiers / versions are driven by app.config.js.
#
# iOS code signing is NOT handled here — the Bitrise "Manage iOS code signing"
# step installs the distribution cert + provisioning profiles (for the app and
# the autofill extension) and configures the project before gym runs.

# Version from package.json (strips suffixes like -alpha).
def get_package_version
  require 'json'
  package_data = JSON.parse(File.read("../package.json"))
  package_data["version"].split("-").first
end

# The single .xcodeproj / .xcworkspace generated by Expo prebuild.
def get_xcodeproj_path
  project = Dir["../ios/*.xcodeproj"].first
  raise "Could not find a .xcodeproj in ../ios/. CWD: #{Dir.pwd}" unless project
  File.expand_path(project)
end

def get_xcworkspace_path
  workspace = Dir["../ios/*.xcworkspace"].first
  raise "Could not find a .xcworkspace in ../ios/. CWD: #{Dir.pwd}" unless workspace
  File.expand_path(workspace)
end

# Scheme name == workspace basename (e.g. AC2). Expo derives both from the app
# name in app.config.js.
def get_scheme
  File.basename(get_xcworkspace_path, ".xcworkspace")
end

def is_ci
  ENV['CI'] == 'true' || ENV['BITRISE_IO'] == 'true'
end

default_platform(:ios)

# ============================================================================
# iOS  ->  TestFlight
# ============================================================================

platform :ios do
  before_all do
    if is_ci
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
        duration: 1200,
        in_house: false
      )
    end
  end

  desc "Build + upload to TestFlight"
  lane :deploy_production do |options|
    deploy_testflight(clean: options[:clean])
  end

  desc "Build + upload to TestFlight"
  lane :deploy_testflight do |options|
    clean = options[:clean].nil? ? true : options[:clean]

    build_ios(clean: clean)

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      ipa: "./build/ios/#{get_scheme}.ipa"
    )
  end

  desc "Archive + export a signed IPA"
  private_lane :build_ios do |options|
    clean = options[:clean].nil? ? true : options[:clean]

    # Version + build number (agvtool covers all targets, incl. the extension).
    increment_version_number(
      version_number: get_package_version,
      xcodeproj: get_xcodeproj_path
    )
    if ENV['BUILD_NUMBER']
      increment_build_number(
        build_number: ENV['BUILD_NUMBER'],
        xcodeproj: get_xcodeproj_path
      )
    end

    # Pin each target to its App Store provisioning profile. Both profiles are
    # installed on the VM by the Bitrise "certificate-and-profile-installer" step
    # from the files uploaded to Code Signing & Files. Per-target because a single
    # global specifier would force the app's profile onto the extension.
    app_bundle_id = "app.perawallet.ac2-wallet"
    extension_bundle_id = "#{app_bundle_id}.PasskeyAutofillCredentialProvider"
    app_profile = "AC2 Wallet"
    extension_profile = "AC2 Wallet Extension"
    team_id = ENV["BITRISE_DEVELOPER_TEAM"] || ENV["IOS_TEAM_ID"]

    update_code_signing_settings(
      path: get_xcodeproj_path,
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      targets: [get_scheme],
      profile_name: app_profile
    )
    update_code_signing_settings(
      path: get_xcodeproj_path,
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      targets: ["PasskeyAutofillCredentialProvider"],
      profile_name: extension_profile
    )

    gym(
      scheme: get_scheme,
      configuration: "Release",
      export_method: "app-store",
      workspace: get_xcworkspace_path,
      output_directory: "./build/ios",
      output_name: "#{get_scheme}.ipa",
      clean: clean,
      export_options: {
        provisioningProfiles: {
          app_bundle_id => app_profile,
          extension_bundle_id => extension_profile
        }
      },
      # Force manual signing for the archive. DEVELOPMENT_TEAM is what the
      # extension target's `$(DEVELOPMENT_TEAM)` resolves from. Mirrors pera-rn.
      xcargs: [
        "CODE_SIGN_STYLE='Manual'",
        "CODE_SIGN_IDENTITY='Apple Distribution'",
        ("DEVELOPMENT_TEAM='#{team_id}'" if team_id)
      ].compact.join(" ")
    )
  end
end

# ============================================================================
# Android  ->  Firebase App Distribution
# ============================================================================

platform :android do
  desc "Build + distribute the release APK to Firebase (ac2-alpha)"
  lane :deploy_production do |options|
    deploy_firebase(clean: options[:clean])
  end

  desc "Build a release APK + upload to Firebase App Distribution"
  lane :deploy_firebase do |options|
    clean = options[:clean].nil? ? true : options[:clean]

    gradle_task = clean ? "clean assemble" : "assemble"
    gradle(
      task: gradle_task,
      build_type: "Release",
      project_dir: "android/",
      # Skip lint-vital — it OOMs (Metaspace) on CI and isn't needed for
      # distribution. Matches the eas.json release gradleCommand.
      flags: "-x lintVitalRelease -x lintVitalAnalyzeRelease --stacktrace",
      properties: {
        "android.injected.version.code" => ENV["BUILD_NUMBER"],
        "android.injected.version.name" => get_package_version
      }
    )

    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"]&.strip,
      groups: (ENV["FIREBASE_TESTER_GROUPS"] || "ac2-alpha").strip,
      release_notes: (ENV["RELEASE_NOTES"] || "Build #{ENV['BUILD_NUMBER'] || 'dev'}").strip,
      android_artifact_type: "APK",
      android_artifact_path: "android/app/build/outputs/apk/release/app-release.apk",
      service_credentials_file: "config/firebase-service-account.json"
    )
  end
end
