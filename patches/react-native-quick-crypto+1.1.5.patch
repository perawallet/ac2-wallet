+  // react-native-quick-base64 installs native implementations of these globals
+  // on import. Only provide JS fallbacks when the natives are missing, otherwise
+  // we would override the native fn with a wrapper that calls back into
+  // fromByteArray (which itself calls global.base64FromArrayBuffer), causing
+  // infinite recursion ("Maximum call stack size exceeded").
+  if (typeof global.base64ToArrayBuffer !== 'function') {
+    global.base64ToArrayBuffer = (s, removeLinebreaks) =>
+      toByteArray(s, removeLinebreaks).buffer as ArrayBuffer;
+  }
+  if (typeof global.base64FromArrayBuffer !== 'function') {
+    global.base64FromArrayBuffer = (b, urlSafe) =>
+      fromByteArray(new Uint8Array(b), urlSafe);
+  }
 };
