    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.5",
    "react": "19.1.0",
    "react-base16-styling": "^0.10.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
