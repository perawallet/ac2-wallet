    "@types/react": "~19.1.0",
    "eas-cli": "^20.1.0",
    "expo-build-properties": "^55.0.9",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.61.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "@algorandfoundation/react-native-keystore": {
      "react-native-mmkv": "$react-native-mmkv",
      "react-native-quick-crypto": "$react-native-quick-crypto"
    },
    "@xmldom/xmldom": "^0.9.10",
    "ajv": "^8.18.0",
    "diff": "^8.0.3",
    "lightningcss": "1.30.1",
    "minimatch": "^9.0.5",
    "node-forge": "^1.4.0",
    "postcss": "^8.5.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-test-renderer": "19.1.0",
    "tar": "^7.5.11",
    "uuid": "^11.1.1",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "@tanstack/store": "0.9.3",
      "@xmldom/xmldom": "^0.9.10",
      "@expo/plist>@xmldom/xmldom": "^0.8.11",
      "ajv": "^8.18.0",
      "diff": "^8.0.3",
      "lightningcss": "1.30.1",
      "minimatch": "^9.0.5",
      "node-forge": "^1.4.0",
      "postcss": "^8.5.10",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-test-renderer": "19.1.0",
      "tar": "^7.5.11",
      "uuid": "^11.1.1",
      "yaml": "^2.9.0"
    },
    "onlyBuiltDependencies": [
