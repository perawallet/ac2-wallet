    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-screen-capture": "~8.0.9",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
